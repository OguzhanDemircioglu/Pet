# ─── NextAuth ───
NEXTAUTH_SECRET=          # openssl rand -base64 32
NEXTAUTH_URL=https://pettoptan.com.tr

# ─── Backend (Spring Boot SaaS API) ───
API_URL=http://localhost:8080              # server-side fetch (RSC + route handlers)
NEXT_PUBLIC_API_URL=http://localhost:8080  # client-side axios

# ─── Public site URL (sitemap.ts için) ───
NEXT_PUBLIC_SITE_URL=https://pettoptan.com.tr

# ─── Google OAuth (opsiyonel) ───
# Google ile giriş istemiyorsanız boş bırakabilirsiniz
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
